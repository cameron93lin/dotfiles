keybind = shift+enter=text:\n
theme = Catppuccin Mocha
#theme = Rose Pine Moon
#theme = Elegant
#theme = Gruvbox Material
font-family = BerkeleyMono Nerd Font
#font-family = Iosevka Nerd Font
# font-family = SFMono Nerd Font 
font-size = 14
#theme = GruvboxDarkHard
shell-integration-features = no-cursor,sudo,no-title
cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.8
adjust-cell-height = 2
background-opacity = 0.85
background-blur = true

mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

window-padding-balance = true 
window-save-state = always
macos-titlebar-style=transparent
macos-option-as-alt = true
window-colorspace = "display-p3"
# foreground = d4be98

# keybindings
keybind = cmd+shift+comma=reload_config
keybind = cmd+w=close_surface
keybind = cmd+n=new_window

# tabs
keybind = cmd+t=new_tab
keybind = cmd+shift+right=next_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+alt+comma=move_tab:-1
keybind = cmd+alt+period=move_tab:1

# quick tab switch
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7
keybind = cmd+8=goto_tab:8
keybind = cmd+9=goto_tab:9

# split
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+down=goto_split:bottom
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+shift+f=toggle_split_zoom
keybind = cmd+shift+e=equalize_splits

# quick terminal
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# tmux shortcuts (sends Ctrl+b prefix + key)
# splits
keybind = ctrl+cmd+d=text:\x02"
keybind = ctrl+cmd+shift+d=text:\x02%
# navigate panes
keybind = ctrl+cmd+left=text:\x02\x1b[D
keybind = ctrl+cmd+right=text:\x02\x1b[C
keybind = ctrl+cmd+down=text:\x02\x1b[B
keybind = ctrl+cmd+up=text:\x02\x1b[A
# zoom & close pane
keybind = ctrl+cmd+f=text:\x02z
keybind = ctrl+cmd+x=text:\x02x
# windows
keybind = ctrl+cmd+t=text:\x02c
keybind = ctrl+cmd+shift+right=text:\x02n
keybind = ctrl+cmd+shift+left=text:\x02p

# font size
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size

# other
copy-on-select = clipboard
scrollback-limit = none
unfocused-split-opacity = 0.7
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
focus-follows-mouse = true
cursor-click-to-move = true
split-inherit-working-directory = true
font-thicken = true
minimum-contrast = 1.1
link-url = true
notify-on-command-finish = unfocused
